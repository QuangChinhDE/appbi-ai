# ============================================================
# AppBI – Docker Compose Environment (Example)
# Copy to .env, adjust values, then run:
#   docker compose up --build -d
# ============================================================

# --- Database (internal network — DB port is NOT exposed to host) ---
DB_USER=appbi
DB_PASSWORD=appbi
DB_NAME=appbi

# --- Backend ---
SECRET_KEY=change-this-in-production-to-random-string
LOG_LEVEL=INFO

# --- Host port mapping ---
# If port 3000 or 8000 is already occupied on your machine,
# change these to any free port (e.g. 3001 / 8001).
# App  → http://localhost:FRONTEND_PORT
# API  → http://localhost:BACKEND_PORT/api/v1
FRONTEND_PORT=3000
BACKEND_PORT=8000

# --- Demo data (optional) ---
# Set to "true" to automatically load the Football/FIFA demo dataset
# on the FIRST startup (creates 1 datasource, 6 datasets, 3 workspaces,
# 9 tables, 18 charts, 3 dashboards — takes ~10 seconds).
# Only runs once; subsequent restarts skip seeding entirely.
# Set to "false" or leave blank to start with an empty database.
SEED_DEMO_DATA=false

# ============================================================
# AI Chat Agent (docker-compose.ai.yml)
# Start with: docker compose -f docker-compose.ai.yml up -d
# ============================================================

# Port for the AI service (default 8001)
AI_PORT=8001

# LLM Provider: openai | anthropic
LLM_PROVIDER=openai
# Model to use (e.g. gpt-4o-mini, gpt-4o, claude-3-5-haiku-20241022)
LLM_MODEL=gpt-4o-mini
# Fallback chain — comma-separated "provider:model" pairs tried in order when primary fails
# Example: openai:gpt-4o-mini,anthropic:claude-3-5-haiku-20241022
LLM_FALLBACK_CHAIN=

# API keys — fill in the key(s) for the provider(s) you use
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Session TTL and limits
AI_SESSION_TTL_MINUTES=30
AI_MAX_TOOL_CALLS=8
AI_WORKSPACE_TABLE_LIMIT=50
