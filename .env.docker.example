# ============================================================
# AppBI – Full Stack Configuration
#
# QUICK START (clone → run):
#   cp .env.docker.example .env
#   docker compose up --build -d
#
# That single command starts: PostgreSQL + Backend + Frontend + AI Agent
# The .data/ folder (Parquet + DuckDB) is created automatically.
# ============================================================

# ── Database ─────────────────────────────────────────────────
# PostgreSQL is used for METADATA only (datasource configs, charts,
# dashboards). Raw synced data is stored in Parquet files, NOT here.
DB_USER=appbi
DB_PASSWORD=appbi
DB_NAME=appbi

# ── Backend ──────────────────────────────────────────────────
# Secret key for session signing. Change this in production.
SECRET_KEY=change-this-in-production-to-a-random-string
LOG_LEVEL=INFO

# DataSource credential encryption (Fernet symmetric key).
# REQUIRED to use external sources (Google Sheets, PostgreSQL, MySQL, BigQuery).
# Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DATASOURCE_ENCRYPTION_KEY=

# ── Demo data ────────────────────────────────────────────────
# Set to "true" to auto-load Football/FIFA demo on FIRST boot only.
# Creates: 1 datasource, 6 datasets, 3 workspaces, 18 charts, 3 dashboards.
# Set to "false" or omit to start with an empty database.
SEED_DEMO_DATA=false

# ── Host port mapping ────────────────────────────────────────
# Change if these ports are already in use on your machine.
FRONTEND_PORT=3000       # → http://localhost:3000
BACKEND_PORT=8000        # → http://localhost:8000/api/v1
AI_PORT=8001             # → http://localhost:8001  (AI Chat Agent)

# ── AI Chat Agent ────────────────────────────────────────────
# The AI service starts alongside the BI stack automatically.
# Fill in at least one API key to enable chat functionality.
# If all keys are empty, the service still starts — chat returns
# an error until a key is configured.

# LLM provider: openai | anthropic | gemini | openrouter
LLM_PROVIDER=openai
# Model (e.g. gpt-4o-mini, gpt-4o, claude-3-5-haiku-20241022, gemini-2.0-flash)
LLM_MODEL=gpt-4o-mini
# Optional fallback chain (tried in order if primary fails):
# e.g. openai:gpt-4o-mini,anthropic:claude-3-5-haiku-20241022
LLM_FALLBACK_CHAIN=

# API keys — fill in the key(s) for your chosen provider(s)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# Advanced AI tuning (safe to leave as defaults)
AI_SESSION_TTL_MINUTES=30
AI_MAX_TOOL_CALLS=8
AI_WORKSPACE_TABLE_LIMIT=50
