# ============================================================
# AppBI - Full Stack Configuration
#
# QUICK START (clone -> run):
#   cp .env.docker.example .env
#   docker compose up --build -d
#
# That single command starts: PostgreSQL + Backend + Frontend
# Optional AI services can be started independently with:
#   docker compose -f docker-compose.yml -f docker-compose.ai.yml up -d --build
#   docker compose -f docker-compose.yml -f docker-compose.chat.yml up -d --build
#   docker compose -f docker-compose.yml -f docker-compose.agent.yml up -d --build
# The .data/ folder (Parquet + DuckDB) is created automatically.
# ============================================================

# Database
# PostgreSQL is used for metadata only (datasource configs, charts, dashboards).
# Raw synced data is stored in Parquet files, not here.
DB_USER=appbi
DB_PASSWORD=appbi
DB_NAME=appbi

# Backend
# Secret key for session signing. Change this in production.
SECRET_KEY=change-this-in-production-to-a-random-string
LOG_LEVEL=INFO

# Admin user (created automatically on first boot)
# If no users exist in the database, entrypoint.sh creates this admin account.
ADMIN_EMAIL=admin@appbi.io
ADMIN_PASSWORD=123456
ADMIN_NAME=Admin

# Demo accounts (created when SEED_DEMO_DATA=true)
# admin@appbi.io / 123456  -> full access (owner)
# edit@appbi.io  / 123456  -> editor role
# viewer@appbi.io / 123456 -> viewer role

# DataSource credential encryption (Fernet symmetric key).
# Required to use external sources (Google Sheets, PostgreSQL, MySQL, BigQuery).
# Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DATASOURCE_ENCRYPTION_KEY=

# Demo data
# Set to "true" to auto-load Football/FIFA demo on first boot only.
# Creates 3 accounts (admin/edit/viewer) + datasource + workspaces + charts + dashboards.
# Set to "false" to start with only the admin account above.
SEED_DEMO_DATA=false

# Host port mapping
# Change if these ports are already in use on your machine.
FRONTEND_PORT=3000
BACKEND_PORT=8000
AI_CHAT_PORT=8001
AI_AGENT_PORT=8002

# AI service configuration
# Chat and Agent are split into separate Docker overlays.
# Use docker-compose.ai.yml if you want both AI services together.
# The base stack does not start either AI service unless you opt in.

# OpenRouter-only AI runtime
# Generic fallback model used when a module-specific model is not set.
LLM_MODEL=openai/gpt-4o-mini
# Optional fallback chain (tried in order if the primary model fails).
# Accepts either plain model names or legacy provider:model entries.
LLM_FALLBACK_CHAIN=
LLM_TIMEOUT_SECONDS=60

# Module-specific model overrides
AI_CHAT_MODEL=openai/gpt-4o-mini
AI_CHAT_FALLBACK_MODELS=
# Keep AI_AGENT_MODEL blank if you want true phase-specific routing below.
AI_AGENT_MODEL=
AI_AGENT_LLM_MODEL=
# Planning is the heaviest reasoning step in AI Reports.
AI_AGENT_PLANNING_MODEL=openai/gpt-4o
# Insight and narrative can stay on a cheaper model by default.
AI_AGENT_INSIGHT_MODEL=openai/gpt-4o-mini
AI_AGENT_NARRATIVE_MODEL=openai/gpt-4o-mini
AI_AGENT_FALLBACK_MODELS=openai/gpt-4o-mini
AI_AGENT_LLM_FALLBACK_CHAIN=
AI_AGENT_LLM_TIMEOUT_SECONDS=60
AI_DESCRIPTION_MODEL=openai/gpt-4o-mini
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
OPENROUTER_EMBEDDING_DIMENSIONS=768

# OpenRouter API keys — set at least one
# Keys are tried in order (1→2→3→4→5). Falls back to bare OPENROUTER_API_KEY.
# Rotation happens automatically on 401/402/403/429 (quota/auth errors).
OPENROUTER_API_KEY=
OPENROUTER_API_KEY_1=
OPENROUTER_API_KEY_2=
OPENROUTER_API_KEY_3=
OPENROUTER_API_KEY_4=
OPENROUTER_API_KEY_5=
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=AppBI

# Advanced AI tuning (safe to leave as defaults)
AI_SESSION_TTL_MINUTES=30
AI_MAX_TOOL_CALLS=8
AI_WORKSPACE_TABLE_LIMIT=50

# Platform-level GCP service account (optional)
# When set, users connecting Google Sheets or BigQuery do NOT need to upload
# a key JSON file — they only need to share their Sheet/dataset with the email below.
# GCP_SERVICE_ACCOUNT_EMAIL=your-sa@your-project.iam.gserviceaccount.com
# GCP_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
