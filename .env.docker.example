# ============================================================
# AppBI - Full Stack Configuration
#
# QUICK START (localhost):
#   cp .env.docker.example .env
#   docker compose -f docker-compose.yml -f docker-compose.ai.yml up -d --build
#
# DOMAIN DEPLOYMENT (e.g. report.base-datateam.com):
#   1. cp .env.docker.example .env
#   2. Fill in [REQUIRED] sections below
#   3. In DOMAIN / URL section: comment out localhost lines, uncomment domain lines
#   4. Set up nginx on the host (config template at the bottom of this file)
#   5. docker compose -f docker-compose.yml -f docker-compose.ai.yml up -d --build
#
# Stack variants:
#   Base BI only:  docker compose up -d --build
#   + Both AI:     docker compose -f docker-compose.yml -f docker-compose.ai.yml up -d --build
#   + Agent only:  docker compose -f docker-compose.yml -f docker-compose.agent.yml up -d --build
#   + Chat only:   docker compose -f docker-compose.yml -f docker-compose.chat.yml up -d --build
# ============================================================


# ============================================================
# DOMAIN / URL  [choose localhost OR domain, not both]
#
# IMPORTANT: NEXT_PUBLIC_* values are baked into the Next.js bundle at BUILD TIME.
#            After changing them you must rebuild:
#            docker compose -f docker-compose.yml -f docker-compose.ai.yml up -d --build
# ============================================================

# --- Localhost (default, uncomment this block for local dev) ---
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_AI_CHAT_WS_URL=ws://localhost:8001/chat/ws
NEXT_PUBLIC_AI_CHAT_HTTP_URL=http://localhost:8001
NEXT_PUBLIC_AI_AGENT_HTTP_URL=http://localhost:8002
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
OPENROUTER_SITE_URL=http://localhost:3000

# --- Public domain with nginx (comment out localhost block above, uncomment this block) ---
# NEXT_PUBLIC_API_URL=https://report.base-datateam.com/api/v1
# NEXT_PUBLIC_AI_CHAT_WS_URL=wss://report.base-datateam.com/chat/ws
# NEXT_PUBLIC_AI_CHAT_HTTP_URL=https://report.base-datateam.com
# NEXT_PUBLIC_AI_AGENT_HTTP_URL=https://report.base-datateam.com/agent
# CORS_ORIGINS=https://report.base-datateam.com
# OPENROUTER_SITE_URL=https://report.base-datateam.com

OPENROUTER_APP_NAME=AppBI


# ============================================================
# DATABASE  [REQUIRED]
# ============================================================
DB_USER=appbi
DB_PASSWORD=appbi
DB_NAME=appbi


# ============================================================
# SECURITY  [REQUIRED — change in production]
# ============================================================
# Random string for JWT signing. Generate with:
#   openssl rand -hex 32
SECRET_KEY=change-this-in-production-to-a-random-string

# Fernet key for encrypting datasource credentials at rest.
# Required to use PostgreSQL, MySQL, BigQuery, Google Sheets sources.
# Generate with:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DATASOURCE_ENCRYPTION_KEY=

LOG_LEVEL=INFO


# ============================================================
# ADMIN ACCOUNT  [REQUIRED]
# Created automatically on first boot if no users exist.
# ============================================================
ADMIN_EMAIL=admin@appbi.io
ADMIN_PASSWORD=123456
ADMIN_NAME=Admin


# ============================================================
# DEMO DATA
# ============================================================
# Set to "true" to auto-load a Football/FIFA demo dataset on first boot.
# Creates admin/edit/viewer accounts + datasource + workspaces + charts + dashboards.
SEED_DEMO_DATA=false


# ============================================================
# HOST PORT MAPPING
# Change if these ports are already in use.
# When using nginx reverse proxy, these are internal only — no need to expose publicly.
# ============================================================
FRONTEND_PORT=3000
BACKEND_PORT=8000
AI_CHAT_PORT=8001
AI_AGENT_PORT=8002


# ============================================================
# LLM / AI MODELS
# ============================================================
# Generic fallback model (used when no phase-specific model is set).
LLM_MODEL=openai/gpt-4o-mini
LLM_FALLBACK_CHAIN=
LLM_TIMEOUT_SECONDS=60

# AI Chat
AI_CHAT_MODEL=openai/gpt-4o-mini
AI_CHAT_FALLBACK_MODELS=

# AI Agent — phase-specific models
# Leave AI_AGENT_MODEL blank to use per-phase routing below.
AI_AGENT_MODEL=
AI_AGENT_LLM_MODEL=
AI_AGENT_ENRICHMENT_MODEL=openai/gpt-4o-mini
AI_AGENT_PLANNING_MODEL=openai/gpt-4o
AI_AGENT_INSIGHT_MODEL=openai/gpt-4o-mini
AI_AGENT_NARRATIVE_MODEL=openai/gpt-4o-mini
AI_AGENT_FALLBACK_MODELS=openai/gpt-4o-mini
AI_AGENT_LLM_FALLBACK_CHAIN=
AI_AGENT_LLM_TIMEOUT_SECONDS=60

# AI Description (backend, runs inside the backend container)
AI_DESCRIPTION_MODEL=openai/gpt-4o-mini
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
OPENROUTER_EMBEDDING_DIMENSIONS=768


# ============================================================
# OPENROUTER API KEYS  [REQUIRED for AI features]
# ============================================================
# Keys are tried in order 1→2→3→4→5.
# On quota/auth error (401/402/403/429) the next key is tried automatically.
# Falls back to bare OPENROUTER_API_KEY if no numbered keys are set.
OPENROUTER_API_KEY=
OPENROUTER_API_KEY_1=
OPENROUTER_API_KEY_2=
OPENROUTER_API_KEY_3=
OPENROUTER_API_KEY_4=
OPENROUTER_API_KEY_5=


# ============================================================
# ADVANCED AI TUNING (safe to leave as defaults)
# ============================================================
AI_SESSION_TTL_MINUTES=30
AI_MAX_TOOL_CALLS=8
AI_WORKSPACE_TABLE_LIMIT=50


# ============================================================
# PLATFORM GCP SERVICE ACCOUNT (optional)
# ============================================================
# When set, users connecting Google Sheets or BigQuery do NOT need to upload
# a credentials JSON key — they only need to share their resource with the
# service-account email below.
GCP_SERVICE_ACCOUNT_EMAIL=
GCP_SERVICE_ACCOUNT_JSON=


