# AI Service — environment variables
# Copy this to .env and fill in real values

# ── BI Backend (internal Docker network) ─────────────────────────────────────
BI_API_URL=http://backend:8000/api/v1

# ── LLM Configuration ────────────────────────────────────────────────────────
# Primary provider: openai | anthropic
LLM_PROVIDER=openai
# Primary model
LLM_MODEL=gpt-4o-mini
# Ordered fallback chain (comma-separated provider:model pairs)
# If primary fails, AI service tries each in order
LLM_FALLBACK_CHAIN=openai:gpt-4o-mini,anthropic:claude-3-5-haiku-20241022

# API keys — leave blank if provider is not used
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=

# ── Session ───────────────────────────────────────────────────────────────────
AI_SESSION_TTL_MINUTES=30
AI_MAX_TOOL_CALLS=8
AI_WORKSPACE_TABLE_LIMIT=50

# ── Server ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
