# AI Service — environment variables
# Copy this to .env and fill in real values

# ── BI Backend (internal Docker network) ─────────────────────────────────────
BI_API_URL=http://backend:8000/api/v1

# ── LLM Configuration ────────────────────────────────────────────────────────
# Primary provider: openai | anthropic | gemini | openrouter
LLM_PROVIDER=openrouter
# Primary model
# OpenRouter models: openai/gpt-4o-mini, anthropic/claude-3-5-haiku, google/gemini-2.0-flash-exp:free
# OpenAI models: gpt-4o-mini, gpt-4o
# Gemini models: gemini-2.0-flash, gemini-1.5-pro
LLM_MODEL=google/gemini-2.0-flash-exp:free
# Ordered fallback chain (comma-separated provider:model pairs)
LLM_FALLBACK_CHAIN=openrouter:google/gemini-2.0-flash-exp:free,openrouter:meta-llama/llama-3.1-8b-instruct:free

# API keys — leave blank if provider is not used
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# OpenRouter key — get free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# ── Session ───────────────────────────────────────────────────────────────────
AI_SESSION_TTL_MINUTES=30
AI_MAX_TOOL_CALLS=8
AI_WORKSPACE_TABLE_LIMIT=50

# ── Server ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
