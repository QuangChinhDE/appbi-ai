# Server Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# Database (Metadata Store — PostgreSQL for schema/config only, NOT raw data)
DATABASE_URL=postgresql://appbi:appbi@localhost:5432/appbi

# Storage (Parquet + DuckDB — raw synced data stored here, NOT in PostgreSQL)
# Relative path → resolved against project root automatically.
# Use an absolute path to override (required in Docker: /app/.data).
DATA_DIR=.data

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Logging
LOG_LEVEL=INFO

# Security
SECRET_KEY=your-secret-key-change-in-production

# DataSource credential encryption (Fernet key — generate with:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave blank to disable encryption (NOT recommended in production).
DATASOURCE_ENCRYPTION_KEY=
