"""
Dashboard Filter Model
Global filters that apply to all compatible charts in a dashboard
"""
from sqlalchemy import Column, Integer, String, JSON, ForeignKey, DateTime, func
from sqlalchemy.orm import relationship
from app.core.database import Base


class DashboardFilter(Base):
    """
    Dashboard-level filter that applies to all compatible charts
    Similar to Looker's dashboard filters
    """
    __tablename__ = "dashboard_filters"
    
    id = Column(Integer, primary_key=True, index=True)
    dashboard_id = Column(Integer, ForeignKey("dashboards.id", ondelete="CASCADE"), nullable=False)
    name = Column(String, nullable=False)  # Display name like "Country Filter"
    field = Column(String, nullable=False)  # Qualified field name like "customers.country"
    type = Column(String, nullable=False)  # string | number | date | datetime
    operator = Column(String, nullable=False)  # eq | ne | in | not_in | contains | gte | lte | between
    value = Column(JSON, nullable=False)  # Filter value(s), can be single or array
    
    created_at = Column(DateTime(timezone=True), server_default=func.now())
    updated_at = Column(DateTime(timezone=True), onupdate=func.now())
    
    # Relationships
    dashboard = relationship("Dashboard", back_populates="filters")
