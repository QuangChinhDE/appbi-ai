# ╔══════════════════════════════════════════════════════════════╗
# ║  AppBI — Unified Environment Configuration                 ║
# ║                                                            ║
# ║  This single file defines ALL variables for every service: ║
# ║    • db (PostgreSQL)                                       ║
# ║    • backend (Python/FastAPI)                               ║
# ║    • frontend (Next.js)                                     ║
# ║    • ai-chat-service (AI Chat)                              ║
# ║    • ai-agent-service (AI Agent)                            ║
# ║                                                            ║
# ║  Quick start:                                               ║
# ║    cp .env.example .env                                     ║
# ║    # Fill in all CHANGE_ME values                           ║
# ║    docker compose up -d --build                             ║
# ║                                                            ║
# ║  With AI services:                                          ║
# ║    docker compose -f docker-compose.yml \                   ║
# ║      -f docker-compose.ai.yml up -d --build                ║
# ║                                                            ║
# ║  Stack variants:                                            ║
# ║    Base BI only:  docker compose up -d --build              ║
# ║    + Both AI:     ... -f docker-compose.ai.yml ...          ║
# ║    + Agent only:  ... -f docker-compose.agent.yml ...       ║
# ║    + Chat only:   ... -f docker-compose.chat.yml ...        ║
# ║    Dev hot-reload: docker compose -f docker-compose.dev.yml ║
# ║                    up --build -d                            ║
# ╚══════════════════════════════════════════════════════════════╝


# ┌──────────────────────────────────────────────────────────────┐
# │  1. ENVIRONMENT MODE                                         │
# │  Used by: backend, ai-chat-service, ai-agent-service         │
# └──────────────────────────────────────────────────────────────┘
# "production" (default) — enforces SECRET_KEY and ENCRYPTION_KEY validation.
# "dev" or "development" — skips secret validation, uses insecure defaults.
ENVIRONMENT=production


# ┌──────────────────────────────────────────────────────────────┐
# │  2. DATABASE                                     [REQUIRED]  │
# │  Used by: db container, backend (via DATABASE_URL)           │
# └──────────────────────────────────────────────────────────────┘
# Docker Compose automatically builds DATABASE_URL from these three values.
# You do NOT need to set DATABASE_URL separately.
DB_USER=appbi
DB_PASSWORD=CHANGE_ME
DB_NAME=appbi


# ┌──────────────────────────────────────────────────────────────┐
# │  3. SECURITY                                     [REQUIRED]  │
# │  Used by: backend, frontend, ai-chat-service, ai-agent       │
# └──────────────────────────────────────────────────────────────┘
# Random string for JWT signing — ALL services must share the same value.
# Generate with:  openssl rand -hex 32
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# Fernet key for encrypting datasource credentials at rest.
# Required in production for PostgreSQL, MySQL, BigQuery, Google Sheets sources.
# Generate with:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DATASOURCE_ENCRYPTION_KEY=

# Cookie secure flag. Set to "false" only for local HTTP development (no HTTPS).
COOKIE_SECURE=true


# ┌──────────────────────────────────────────────────────────────┐
# │  4. ADMIN ACCOUNT                               [REQUIRED]  │
# │  Used by: backend (first-boot seed)                          │
# └──────────────────────────────────────────────────────────────┘
# Created automatically on first boot if no users exist.
ADMIN_EMAIL=admin@appbi.io
ADMIN_PASSWORD=CHANGE_ME
ADMIN_NAME=Admin


# ┌──────────────────────────────────────────────────────────────┐
# │  5. DOMAIN / URLS                                            │
# │  Used by: frontend (build-time), backend, AI services        │
# └──────────────────────────────────────────────────────────────┘
# Baked into Next.js bundle at BUILD TIME. Relative path works on any domain.
NEXT_PUBLIC_API_URL=/api/v1

# Allow requests from these origins (comma-separated).
# For domain deployment, add your domain:
#   CORS_ORIGINS=http://localhost:3000,https://your-domain.com
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# OpenRouter request metadata
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=AppBI


# ┌──────────────────────────────────────────────────────────────┐
# │  6. HOST PORT MAPPING                                        │
# │  Used by: docker-compose port bindings                       │
# └──────────────────────────────────────────────────────────────┘
# Change if these ports are already in use on your host.
# When using nginx reverse proxy, these are internal only.
FRONTEND_PORT=3000
BACKEND_PORT=8000
AI_CHAT_PORT=8001
AI_AGENT_PORT=8002


# ┌──────────────────────────────────────────────────────────────┐
# │  7. DEMO DATA                                                │
# │  Used by: backend                                            │
# └──────────────────────────────────────────────────────────────┘
# Set to "true" to auto-load a Football/FIFA demo dataset on first boot.
# Creates admin/edit/viewer accounts + datasource + datasets + charts + dashboards.
SEED_DEMO_DATA=false


# ┌──────────────────────────────────────────────────────────────┐
# │  8. LOGGING                                                  │
# │  Used by: backend, ai-chat-service, ai-agent-service         │
# └──────────────────────────────────────────────────────────────┘
LOG_LEVEL=INFO


# ┌──────────────────────────────────────────────────────────────┐
# │  9. OPENROUTER API KEYS              [REQUIRED for AI]       │
# │  Used by: backend, ai-chat-service, ai-agent-service         │
# └──────────────────────────────────────────────────────────────┘
# Keys are tried in order 1→2→3→4→5, then bare OPENROUTER_API_KEY.
# On quota/auth error (401/402/403/429) the next key is tried automatically.
# Get your keys at: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_API_KEY_1=
OPENROUTER_API_KEY_2=
OPENROUTER_API_KEY_3=
OPENROUTER_API_KEY_4=
OPENROUTER_API_KEY_5=


# ┌──────────────────────────────────────────────────────────────┐
# │  10. LLM MODELS — Generic                                   │
# │  Used by: ai-chat-service, ai-agent-service                  │
# └──────────────────────────────────────────────────────────────┘
# Default model when no service-specific model is set.
LLM_MODEL=openai/gpt-4o-mini
# Ordered fallback chain (comma-separated provider:model pairs).
LLM_FALLBACK_CHAIN=
# Global LLM call timeout in seconds.
LLM_TIMEOUT_SECONDS=60


# ┌──────────────────────────────────────────────────────────────┐
# │  11. LLM MODELS — AI Chat                                   │
# │  Used by: ai-chat-service                                    │
# └──────────────────────────────────────────────────────────────┘
# Override model specifically for AI Chat (falls back to LLM_MODEL).
AI_CHAT_MODEL=
# Chat-specific fallback chain (falls back to LLM_FALLBACK_CHAIN).
AI_CHAT_FALLBACK_MODELS=


# ┌──────────────────────────────────────────────────────────────┐
# │  12. LLM MODELS — AI Agent (phase-specific)                 │
# │  Used by: ai-agent-service                                   │
# └──────────────────────────────────────────────────────────────┘
# Agent-wide model override. Leave blank to use per-phase routing below.
AI_AGENT_MODEL=
AI_AGENT_LLM_MODEL=

# Phase-specific model overrides (each falls back to AI_AGENT_MODEL → LLM_MODEL):
AI_AGENT_ENRICHMENT_MODEL=
AI_AGENT_PLANNING_MODEL=
AI_AGENT_INSIGHT_MODEL=
AI_AGENT_NARRATIVE_MODEL=

# Agent-specific fallback chain.
AI_AGENT_FALLBACK_MODELS=
AI_AGENT_LLM_FALLBACK_CHAIN=
# Agent-specific timeout (0 = use LLM_TIMEOUT_SECONDS).
AI_AGENT_LLM_TIMEOUT_SECONDS=0


# ┌──────────────────────────────────────────────────────────────┐
# │  13. LLM MODELS — Backend AI Features                       │
# │  Used by: backend (AI column descriptions, embeddings)       │
# └──────────────────────────────────────────────────────────────┘
AI_DESCRIPTION_MODEL=openai/gpt-4o-mini
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
OPENROUTER_EMBEDDING_DIMENSIONS=768


# ┌──────────────────────────────────────────────────────────────┐
# │  14. AI CHAT SESSION TUNING                                  │
# │  Used by: ai-chat-service                                    │
# └──────────────────────────────────────────────────────────────┘
AI_SESSION_TTL_MINUTES=30
AI_MAX_TOOL_CALLS=8
AI_DATASET_TABLE_LIMIT=50


# ┌──────────────────────────────────────────────────────────────┐
# │  15. GCP SERVICE ACCOUNT (optional)                          │
# │  Used by: backend                                            │
# └──────────────────────────────────────────────────────────────┘
# When set, users connecting Google Sheets or BigQuery do NOT need to upload
# a credentials JSON — they only need to share their resource with this email.
GCP_SERVICE_ACCOUNT_EMAIL=
GCP_SERVICE_ACCOUNT_JSON=


# ┌──────────────────────────────────────────────────────────────┐
# │  16. FRONTEND AI SERVICE OVERRIDES (rarely needed)           │
# │  Used by: frontend (client-side, browser)                    │
# └──────────────────────────────────────────────────────────────┘
# AI service URLs are auto-detected from window.location in the browser.
# You do NOT need these if AI services run behind the same nginx as the frontend.
# Only set these if AI services run on a DIFFERENT host entirely.
# NEXT_PUBLIC_AI_CHAT_WS_URL=wss://other-ai-host.com/chat/ws
# NEXT_PUBLIC_AI_CHAT_HTTP_URL=https://other-ai-host.com
# NEXT_PUBLIC_AI_AGENT_HTTP_URL=https://other-ai-host.com


# ┌──────────────────────────────────────────────────────────────┐
# │  17. NGINX (domain deployment notes)                         │
# └──────────────────────────────────────────────────────────────┘
# See nginx.conf in the repo root for the complete ready-to-use config.
#
# Quick setup:
#   sudo apt install -y nginx certbot python3-certbot-nginx
#   sudo cp nginx.conf /etc/nginx/nginx.conf
#   # Edit server_name in nginx.conf to your domain
#   sudo nginx -t && sudo systemctl reload nginx
#   sudo certbot --nginx -d your-domain.com
